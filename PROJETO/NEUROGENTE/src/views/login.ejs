<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - NEUROGENTE</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧠</text></svg>">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="login-wrapper">
        <div class="login-box">
            <h1>🧠 NEUROGENTE</h1>
            <p>Identifique-se para acessar</p>
            
            <% if (erro) { %>
                <div class="error-msg"><%= erro %></div>
            <% } %>

            <form action="/autenticar" method="POST">
                <input type="text" name="username" placeholder="Usuário" required>
                <input type="password" name="password" placeholder="Senha" required>
                <button type="submit" class="btn" style="width:100%; background: #00d2ff; color:#333;">Entrar</button>
            </form>

            <div style="margin-top: 20px; text-align: center;">
                <a href="http://neurocenter.local" style="color: #bbb; text-decoration: none; font-size: 0.85rem;">⬅ Voltar ao Portal Corporativo</a>
            </div>
        </div>
    </div>
</body>
</html>