<div id="atestados">
    <h2>📋 Homologação de Atestados</h2>
    <div class="split-container">
        <div class="pdf-viewer">
            <embed src="/uploads/regra_atestado.pdf" type="application/pdf" width="100%" height="600px" />
        </div>
        
        <div class="form-box">
            <h3>Protocolo de Atestado</h3>
            <p style="font-size:0.8rem;">Envio digital para o RH (Substitui a entrega física imediata).</p>
            
            <form action="/upload-atestado" method="POST" enctype="multipart/form-data">
                <label>Colaborador:</label>
                <input type="text" value="<%= user.username %>" disabled>
                
                <label>Data de Início do Afastamento:</label>
                <input type="date" name="data_inicio" required>
                
                <label>Quantidade de Dias:</label>
                <input type="number" name="dias" min="1" required style="width: 100px;">

                <label>Arquivo (Foto legível ou PDF):</label>
                <input type="file" name="arquivo" accept="image/*,.pdf" required>

                <br><br>
                <button type="submit" class="btn">Protocolar Atestado</button>
            </form>
        </div>
    </div>
</div>